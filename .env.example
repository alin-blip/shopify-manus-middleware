# ============================================
# Shopify-Manus Integration — Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Shopify App Credentials
SHOPIFY_CLIENT_ID=7f630fbb79b54b156610dbc7b3a91c7e
SHOPIFY_CLIENT_SECRET=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
SHOPIFY_STORE_DOMAIN=ykiysp-be.myshopify.com
SHOPIFY_API_VERSION=2024-01

# Shopify Webhook Secret (HMAC verification)
# This is the same as SHOPIFY_CLIENT_SECRET for custom apps
SHOPIFY_WEBHOOK_SECRET=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

# Manus EduForYou Platform
MANUS_BASE_URL=https://www.eduforyou.co.uk
MANUS_API_URL=https://www.eduforyou.co.uk/api/trpc

# Integration Auth Secret (for signing cross-platform tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INTEGRATION_JWT_SECRET=your-random-64-byte-hex-secret-here

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=https://www.eduforyou.co.uk,https://ykiysp-be.myshopify.com

# Logging
LOG_LEVEL=info
